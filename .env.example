# Copy to .env and fill in your keys:
# cp .env.example .env

# OpenWeatherMap — for live weather in news (optional; weather omitted if missing)
# Get free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Gemini — for voice summary in farmer's language (optional; voice_summary null if missing)
# Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
